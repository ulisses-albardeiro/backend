<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>Ordem de Serviço {{ order.code }}</title>
        <style>
            body {
                font-family: 'Helvetica', 'Arial', sans-serif;
                color: #333;
                font-size: 11px;
                line-height: 1.4;
            }
            .header {
                border-bottom: 2px solid #eee;
                padding-bottom: 20px;
                margin-bottom: 20px;
            }
            .logo {
                max-width: 150px;
                max-height: 80px;
                margin-bottom: 10px;
            }
            .company-details {
                font-size: 10px;
                color: #666;
            }
            
            /* ================================================================= */
            /* ESTILOS DA TABELA REESTRUTURADOS PARA ALINHAMENTO PERFEITO EM PDF */
            /* ================================================================= */
            .table {
                width: 100%;
                border-collapse: collapse;
                margin-bottom: 20px;
                table-layout: auto;
            }
            .table th {
                background-color: #f8f8f8;
                padding: 8px;
                border-bottom: 2px solid #ddd;
                font-weight: bold;
            }
            .table td {
                padding: 8px;
                border-bottom: 1px solid #eee;
                vertical-align: middle;
            }
            
            /* Classes de controle por peso em percentual (evita bugs de sub-pixels) */
            .col-desc { text-align: left; }
            .col-qtd { text-align: right; width: 15%; white-space: nowrap; }
            .col-unit { text-align: right; width: 20%; white-space: nowrap; }
            .col-total { text-align: right; width: 20%; white-space: nowrap; }
            /* ================================================================= */

            .info-grid {
                width: 100%;
                margin-bottom: 20px;
            }
            .info-box {
                border: 1px solid #eee;
                padding: 10px;
                vertical-align: top;
                width: 50%;
            }
            .section-title {
                font-size: 10px;
                color: #666;
                font-weight: bold;
                margin-bottom: -10px;
                text-transform: uppercase;
                border-bottom: 1px solid #eee;
                padding-bottom: 20px; /* Corrigido padding para evitar quebras visuais */
                margin-top: 15px;
            }
            .content-block {
                background: #fdfdfd;
                padding: 8px;
                border: 1px solid #f0f0f0;
            }
            .totals {
                float: right;
                width: 250px;
                margin-top: 20px;
            }
            .totals-row {
                width: 100%;
                border-bottom: 1px solid #eee;
                padding: 5px 0;
            }
            .totals-row.grand-total {
                border-bottom: none;
                font-weight: bold;
                font-size: 14px;
                color: #000;
                padding-top: 10px;
            }
            .text-right {
                text-align: right;
            }
            .status-badge {
                padding: 4px 8px;
                border-radius: 4px;
                color: #fff;
                font-weight: bold;
                text-transform: uppercase;
                font-size: 9px;
            }
            .item-photo-box {
                display: inline-block;
                width: 150px;
                height: 80px;
                margin: 0 8px 8px 0;
                border: 1px solid #eee;
                text-align: center;
                vertical-align: top;
                overflow: hidden;
            }
            .item-photo-box img {
                max-width: 148px;
                max-height: 78px;
            }
            .footer {
                position: fixed;
                bottom: -20px;
                width: 100%;
                text-align: center;
                font-size: 9px;
                color: #999;
                border-top: 1px solid #eee;
                padding-top: 5px;
            }
        </style>
    </head>
    <body>

        <div class="header">
            <table style="width: 100%;">
                <tr>
                    <td style="width: 60%;">
                        {% if company.logo %}
                            <img src="{{ company.logo }}" class="logo">
                        {% endif %}
                        <div class="company-details">
                            <strong>{{ company.tradingName ?: company.name }}</strong><br>

                            {% if company.registrationNumber %}
                                CNPJ: {{ company.registrationNumber }}<br>
                            {% endif %}

                            {% if company.street %}
                                {{ company.street }}{{ company.number ? ', ' ~ company.number }}{{ company.complement ? ' - ' ~ company.complement }}<br>
                            {% endif %}

                            {% if company.email or company.phone %}
                                {{ company.email }}{{ (company.email and company.phone) ? ' | ' }}{{ company.phone }}
                            {% endif %}
                        </div>
                    </td>
                    <td class="text-right" style="vertical-align: top;">
                        <h1 style="margin: 0; color: #444; font-size: 20px;">ORDEM DE SERVIÇO</h1>
                        <div style="margin: 10px 0;">
                            <span class="status-badge" style="background-color: #666;">
                                {{ order.statusLabel }}
                            </span>
                        </div>
                        <strong>Nº {{ order.code }}</strong><br>
                        <span>Abertura: {{ order.createdAt|date('d/m/Y H:i') }}</span>
                    </td>
                </tr>
            </table>
        </div>

        <table class="info-grid" style="border-spacing: 0;">
            <tr>
                <td class="info-box" style="border-right: none;">
                    <div class="section-title">Dados do Cliente</div>
                    <strong>{{ customer.name }}</strong><br>
                    {% if customer.document %}Doc: {{ customer.document }}<br>{% endif %}
                    {% if customer.email %}{{ customer.email }}<br>{% endif %}
                    {% if customer.phone %}{{ customer.phone }}{% endif %}
                </td>
                <td class="info-box">
                    <div class="section-title">Informações Técnicas</div>
                    {% if order.equipment %}
                        <strong>Equipamento/Local:</strong> {{ order.equipment }}<br>
                    {% endif %}
                    <strong>Início:</strong> {{ order.startDate ? order.startDate|date('d/m/Y') : '-' }}<br>
                    <strong>Previsão/Fim:</strong> {{ order.endDate ? order.endDate|date('d/m/Y') : '-' }}
                </td>
            </tr>
        </table>

        {% if order.assetName %}
            <div class="section-title">Bem Associado</div>
            <div class="content-block">
                {{ order.assetName }}
            </div>
        {% endif %}
        
        <div class="section-title">Descrição do Problema</div>
        <div class="content-block">
            {{ order.problemDescription|nl2br }}
        </div>

        {% if order.technicalReport %}
            <div class="section-title">Laudo Técnico / Execução</div>
            <div class="content-block">
                {{ order.technicalReport|nl2br }}
            </div>
        {% endif %}

        <div class="section-title">Peças e Serviços</div>
        
        <table class="table">
            <thead>
                <tr>
                    <th class="col-desc">Descrição</th>
                    <th class="col-qtd">Qtd</th>
                    <th class="col-unit">Unitário</th>
                    <th class="col-total">Total</th>
                </tr>
            </thead>
            <tbody>
                {% for item in order.items %}
                    <tr>
                        <td class="col-desc">{{ item.productName ?: item.laborName ?: item.description }}</td>
                        <td class="col-qtd">{{ item.quantity }} {{ item.productUnit }}{{ item.laborUnit }}</td>
                        <td class="col-unit">R$ {{ (item.unitPrice / 100)|number_format(2, ',', '.') }}</td>
                        <td class="col-total">R$ {{ (item.totalPrice / 100)|number_format(2, ',', '.') }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        {% set hasPhotos = false %}
        {% for item in order.items %}
            {% if photosByItemId[item.id] is defined and photosByItemId[item.id]|length > 0 %}
                {% set hasPhotos = true %}
            {% endif %}
        {% endfor %}

        {% if hasPhotos %}
            <div style="margin-top: 15px;">
                <div style="font-size: 10px; color: #666; font-weight: bold;">FOTOS DOS ITENS:</div>
                {% for item in order.items %}
                    {% if photosByItemId[item.id] is defined and photosByItemId[item.id]|length > 0 %}
                        <div style="margin-top: 10px; page-break-inside: avoid;">
                            <div style="font-size: 10px; font-weight: bold; margin-bottom: 5px;">Item {{ loop.index }} — {{ item.productName ?: item.laborName ?: item.description }}</div>
                            <div>
                                {% for photo in photosByItemId[item.id] %}
                                    <span class="item-photo-box"><img src="{{ photo }}"></span>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}

        <div class="totals">
            <div class="totals-row grand-total">
                <span>VALOR TOTAL:</span>
                <span style="float: right;">R$ {{ (order.totalAmount / 100)|number_format(2, ',', '.') }}</span>
            </div>
        </div>

        <div style="clear: both;"></div>

        <div style="margin-top: 50px;">
            <table style="width: 100%;">
                <tr>
                    <td style="width: 45%; border-top: 1px solid #333; text-align: center; padding-top: 5px;">
                        Assinatura do Técnico
                    </td>
                    <td style="width: 10%;"></td>
                    <td style="width: 45%; border-top: 1px solid #333; text-align: center; padding-top: 5px;">
                        Assinatura do Cliente
                    </td>
                </tr>
            </table>
        </div>

        <div class="footer">
            {{ company.tradingName ?: company.name }} - OS gerada em {{ "now"|date('d/m/Y H:i') }}
        </div>

    </body>
</html>
